  <!-- Hero Section -->
  <header class="hero-section fade-in" id="hero" data-controller="hero">
    <img src="<%= asset_path('guitare.jpg') %>"
       alt="Fond guitare"
       class="hero-bg"
       data-hero-target="bg">
    <div class="container hero-text" data-navbar-target="heroText">
      <div class="logo">
        <span class="eco">ECOL</span><span class="a">ā</span><span class="zik">ZIK</span>
      </div>
      <p>Des cours flexibles et personnalisés à Amiens</p>
      <a href="mailto:ecolazik@gmail.com" class="btn-primary">Réserve ton cours d'essai</a>
    </div>
  </header>

  <!-- Services Section -->
  <section class="services" id="services" data-controller="services">
      <div class="container services-grid">
        <div class="service" data-services-target="service">
        <img src="<%= asset_path('flexibilite.png') %>" alt="Flexibilité" class="service-icon">
        <h2>⏰ Flexibilité</h2>
        <p>Réserve ton cours selon ton emploi du temps, en toute liberté.</p>
      </div>

      <div class="service" data-services-target="service">
        <img src="<%= asset_path('professeur.png') %>" alt="Qualité pédagogique" class="service-icon">
        <h2>🎓 Qualité pédagogique</h2>
        <p>Des professeurs passionnés et expérimentés dans chaque discipline.</p>
      </div>

      <div class="service" data-services-target="service">
        <img src="<%= asset_path('groupe.png') %>" alt="Ambiance conviviale" class="service-icon">
        <h2>🤝 Ambiance conviviale</h2>
        <p>Un cadre chaleureux pour apprendre avec plaisir et motivation.</p>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
 <section class="testimonials" id="testimonials" data-controller="testimonials">
  <div class="container">
    <h2>💬 Ce que disent nos élèves</h2>

    <div class="testimonial-slider">
      <!-- track -->
      <div class="testimonial-track" data-testimonials-target="track">
        <% @testimonials.each do |testimonial| %>
          <div class="testimonial-slide" data-testimonials-target="slide">
            <blockquote>
              <p><%= testimonial.content %></p>
              <cite>– <%= testimonial.author %></cite>
            </blockquote>
          </div>
        <% end %>
      </div>
      <div class="slider-dots" data-testimonials-target="dots"></div>

      <div class="big-separator"></div>
      <!-- contrôles -->
      <div class="slider-controls">
        <button class="slider-btn prev" data-action="click->testimonials#prev">❮</button>
        <button class="slider-btn next" data-action="click->testimonials#next">❯</button>
      </div>
    </div>

    <section class="jobs" id="jobs">
      <div class="container jobs-content">
        <h2>Rejoins l’équipe Ecolazik</h2>
        <p class="jobs-intro">
          Tu es professeur·e de musique, passionné·e par la pédagogie et l’envie de transmettre ?
          Nous sommes toujours à l’écoute de nouvelles candidatures pour étoffer notre équipe.
        </p>

        <div class="jobs-grid">
          <div class="jobs-block">
            <h3>Professeurs recherchés</h3>
            <ul>
              <li>Prof de piano</li>
              <li>Prof de MAO</li>
              <li>Prof de violon</li>
              <li>Autres instruments bienvenus !</li>
            </ul>
          </div>

          <div class="jobs-block">
            <h3>Ce que nous aimons</h3>
            <ul>
              <li>Une pédagogie bienveillante et adaptée à chaque élève</li>
              <li>Une vraie passion pour la musique et le partage</li>
              <li>Envie de s’investir dans un projet local</li>
            </ul>
            <p class="jobs-contact">
              📩 Envoie ton CV et quelques mots sur toi :
            </p>
            <a href="mailto:ecolazik@gmail.com?subject=Candidature professeur" class="btn-primary jobs-btn">
              Envoyer ma candidature
            </a>
          </div>
        </div>
      </div>
    </section>
    <!-- dots -->
  </div>
</section>
  <!-- CTA Section -->
  <section class="cta" id="cta">
    <div class="container">
      <h2>Prêt.e à commencer ton aventure musicale ?</h2>
      <a href="mailto:ecolazik@gmail.com" class="btn-primary">Réserve ton cours d'essai</a>
    </div>
  </section>

</body>
</body>
