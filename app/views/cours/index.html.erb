<%= render "shared/back_to_home" %>

<!-- HERO COURS -->
<section class="cours-hero">
  <div class="container">
    <h1>Nos cours & ateliers</h1>
    <p>
      Découvre tous les instruments proposés chez <strong>EcolaZik</strong>,
      ainsi que nos ateliers collectifs pour jouer ensemble et progresser.
    </p>
  </div>
</section>

<!-- INSTRUMENTS -->
<section class="cours-section" id="instruments">
  <div class="container">
    <h2>Cours d’instruments</h2>

    <div class="instruments-grid">
      <div class="instrument-card">
        <h3>Guitare & Ukulele</h3>
        <p>Acoustique ou électrique, pour débutants et confirmés.</p>
      </div>

      <div class="instrument-card">
        <h3>Piano</h3>
        <p>Classique, moderne ou accompagnement.</p>
      </div>

      <div class="instrument-card">
        <h3>Basse</h3>
        <p>Groove, technique et jeu en groupe.</p>
      </div>

      <div class="instrument-card">
        <h3>Batterie</h3>
        <p>Rythme, coordination et énergie.</p>
      </div>

      <div class="instrument-card">
        <h3>Chant</h3>
        <p>Technique vocale, interprétation et confiance.</p>
      </div>

      <div class="instrument-card">
        <h3>Saxophone</h3>
        <p>Jazz, funk ou musique actuelle, pour débutants et confirmés.</p>
      </div>
    </div>
  </div>
</section>

<!-- ATELIERS COLLECTIFS -->
<section class="cours-section ateliers">
  <div class="container">
    <h2>Ateliers collectifs</h2>

    <div class="ateliers-grid">
      <div class="atelier-card">
        <h3>Atelier groupe</h3>
        <p>
          Joue en groupe, apprends à écouter les autres et monte des morceaux
          ensemble.
        </p>
      </div>

      <div class="atelier-card">
        <h3>Eveil musical</h3>
        <p>
          Pour les musiciens en herbe ! De 4 à 6 ans.
        </p>
      </div>

      <div class="atelier-card">
        <h3>Atelier composition</h3>
        <p>
          Travail de l'harmonie et de l'écriture musicale. Accessible à tous niveaux !
        </p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="container">
    <h2>Envie d’essayer ?</h2>
    <a href="mailto:ecolazik@gmail.com" class="btn-primary">
      Réserve ton cours d’essai
    </a>
  </div>
</section>
