<%= render "shared/back_to_home" %>

<!-- HERO TARIFS -->
<section class="tarifs-hero">
  <div class="container">
    <h1>Nos tarifs</h1>
    <p>
      Des formules simples et flexibles, adaptées à tous les profils.
    </p>
  </div>
</section>

<!-- TARIFS -->
<section class="tarifs-section">
  <div class="container tarifs-grid">

    <div class="tarif-card">
      <h3>Cours à la carte</h3>
      <div class="tarif-price">30€</div>
      <p>1 cours individuel, sans engagement.</p>
    </div>

    <div class="tarif-card highlight">
      <span class="badge">Étudiant</span>
      <h3>Tarif étudiant</h3>
      <div class="tarif-price">23€</div>
      <p>Sur présentation d’un justificatif.</p>
    </div>

    <div class="tarif-card">
      <h3>Forfait 5 cours</h3>
      <div class="tarif-price">125€</div>
      <p>Soit <strong>25€ / cours</strong>.</p>
    </div>

    <div class="tarif-card">
      <h3>Atelier collectif</h3>
      <div class="tarif-price">20€</div>
      <p>Par séance (2 séances par mois).</p>
    </div>

  </div>
</section>

<!-- INFOS -->
<section class="tarifs-info">
  <div class="container">
    <p>
      🎸 Les cours durent 45 mins<br>
      ⏰ Horaires flexibles selon vos disponibilités
    </p>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="container">
    <h2>Besoin d’un conseil ?</h2>
    <a href="mailto:ecolazik@gmail.com" class="btn-primary">
      Contacte-nous
    </a>
  </div>
</section>
